# ─── Claude / Anthropic ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google ────────────────────────────────────────────────────────────────────
# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEETS_ID=THIS_PART_HERE

# ─── WhatsApp (Meta Business Cloud API) ───────────────────────────────────────
# From developers.facebook.com → your app → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxx...
# Phone number with country code, NO plus sign. e.g. India: 919876543210
WHATSAPP_RECIPIENT=919876543210

# ─── OpenAI (optional — enables GPT-4o in the Chat tab) ──────────────────────
OPENAI_API_KEY=sk-...

# ─── Google AI (optional — enables Gemini in the Chat tab) ───────────────────
GOOGLE_AI_API_KEY=AIza...

# ─── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8765
